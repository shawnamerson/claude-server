# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
DOMAIN=claudeserver.app

# Let's Encrypt email
ACME_EMAIL=you@example.com

# DNS provider for wildcard certs (for *.claudeserver.app subdomain routing)
# Options: cloudflare, route53, digitalocean, etc.
# See: https://doc.traefik.io/traefik/https/acme/#providers
DNS_PROVIDER=cloudflare

# Cloudflare credentials (if using cloudflare)
CF_API_EMAIL=
CF_API_KEY=
